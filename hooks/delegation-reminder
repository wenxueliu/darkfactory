#!/usr/bin/env bash
# delegation-reminder — PostToolUse hook for Harness multiagents
# Event: PostToolUse (Bash|Write|Edit|Read|Grep|Glob|Agent|TodoWrite|Skill)
# Purpose: Reminds orchestrator agents (hw-controller, hw-plan-executor) to
#           delegate non-trivial work to specialized subagents. After 3+
#           direct tool calls without delegation, injects a reminder message.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
STATE_DIR="${PLUGIN_ROOT}/hooks/hook-state/delegation-reminder"
mkdir -p "$STATE_DIR"

# --- Parse stdin JSON ---
INPUT_JSON=$(cat)

session_id=$(python3 -c "import json,sys; print(json.loads(sys.stdin.read()).get('session_id',''))" <<< "$INPUT_JSON" 2>/dev/null || echo "")
tool_name=$(python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('tool_name',''))" <<< "$INPUT_JSON" 2>/dev/null || echo "")

if [ -z "$session_id" ]; then
  exit 0
fi

# --- Load or create state ---
STATE_FILE="${STATE_DIR}/${session_id}.json"

if [ -f "$STATE_FILE" ]; then
  has_delegated=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(str(d.get('hasDelegated','false')).lower())" "$STATE_FILE" 2>/dev/null || echo "false")
  reminder_shown=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(str(d.get('reminderShown','false')).lower())" "$STATE_FILE" 2>/dev/null || echo "false")
  tool_call_count=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d.get('toolCallCount',0))" "$STATE_FILE" 2>/dev/null || echo "0")
else
  has_delegated="false"
  reminder_shown="false"
  tool_call_count="0"
fi

# --- Detect delegation ---
# Agent tool or Skill tool usage counts as delegation
if [ "$tool_name" = "Agent" ] || [ "$tool_name" = "Skill" ]; then
  python3 -c "
import json,time,sys
state = {'sessionID': sys.argv[1], 'hasDelegated': True, 'reminderShown': False, 'toolCallCount': 0, 'updatedAt': int(time.time())}
with open(sys.argv[2], 'w') as f:
    json.dump(state, f, indent=2)
" "$session_id" "$STATE_FILE" 2>/dev/null || true
  exit 0
fi

# --- Track delegatable tool calls ---
DELEGATABLE_TOOLS="Bash,Write,Edit,Read,Grep,Glob,Task,TodoWrite,WebFetch,WebSearch"
is_delegatable="false"
IFS=',' read -ra TOOLS <<< "$DELEGATABLE_TOOLS"
for t in "${TOOLS[@]}"; do
  if [ "$tool_name" = "$t" ]; then
    is_delegatable="true"
    break
  fi
done

if [ "$is_delegatable" != "true" ]; then
  exit 0
fi

# Increment counter
tool_call_count=$((tool_call_count + 1))

# --- Check if reminder should fire ---
# Fire on 3rd delegatable tool call (not earlier to avoid noise)
should_remind="false"
if [ "$tool_call_count" -ge 3 ] && [ "$has_delegated" = "false" ] && [ "$reminder_shown" = "false" ]; then
  should_remind="true"
  reminder_shown="true"
fi

# --- Save state ---
python3 -c "
import json,time,sys
state = {
    'sessionID': sys.argv[1],
    'hasDelegated': sys.argv[2] == 'true',
    'reminderShown': sys.argv[3] == 'true',
    'toolCallCount': int(sys.argv[4]),
    'updatedAt': int(time.time())
}
with open(sys.argv[5], 'w') as f:
    json.dump(state, f, indent=2)
" "$session_id" "$has_delegated" "$reminder_shown" "$tool_call_count" "$STATE_FILE" 2>/dev/null || true

# --- No reminder needed ---
if [ "$should_remind" != "true" ]; then
  exit 0
fi

# --- Build and inject reminder ---
REMINDER="\\n[Delegation Reminder — Harness Multi-Agent System]\\n\
You have made ${tool_call_count} direct tool calls without delegating to subagents.\\n\
\\n\
hw-controller delegation rules:\\n\
- Delegate non-trivial work to specialized agents via parallel Agent calls\\n\
- Explore: hw-codebase-explorer (internal) + hw-external-researcher (external)\\n\
- Plan: hw-strategic-planner for multi-step or ambiguous work\\n\
- Execute: hw-plan-executor for multi-task plans, hw-worktree-controller for single tasks\\n\
- Review: hw-reviewer-logic + hw-reviewer-security + hw-reviewer-performance + hw-reviewer-context\\n\
- Advise: hw-strategic-advisor for deep architecture/security reasoning\\n\
\\n\
ALWAYS prefer delegation over direct tool calls for non-trivial work."

ESCAPED=$(python3 -c "
import json,sys
print(json.dumps(sys.argv[1]))
" "$REMINDER" 2>/dev/null || echo "\"$REMINDER\"")

# Output context injection (follow session-start platform detection pattern)
if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{"hookSpecificOutput":{"hookEventName":"PostToolUse","additionalContext":"%s"}}\n' "$REMINDER"
else
  printf '{"additionalContext":"%s"}\n' "$REMINDER"
fi

exit 0
